# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_BASE_URL: Optional custom Gemini-compatible endpoint base URL.
# Set this when routing requests through a proxy/gateway.
GEMINI_BASE_URL="MY_GEMINI_BASE_URL"

GEMINI_DRILLDOWN_MAX_DEPTH="2"
GEMINI_KEY_SUBFUNCTION_COUNT="10"

# Retry policy for transient browser/network errors (e.g. "Failed to fetch")
GEMINI_RETRY_MAX_RETRIES="0"
GEMINI_RETRY_BASE_DELAY_MS="600"

# Optional model override for all AI analysis calls
GEMINI_MODEL="gemini-3-flash-preview"

GITHUB_TOKEN="MY_GITHUB_TOKEN"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
